rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: products
    // Fields:
    //   - id: string (required)
    //   - name: string (required, max 100)
    //   - description: string (optional, max 500)
    //   - category: string (optional, max 50)
    //   - price: number (required, positive)
    //   - quantity: number (required, non-negative)
    //   - sku: string (required, unique-ish)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - createdBy: string (required)
    //
    // Collection: activityLogs
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - action: string (required)
    //   - productId: string (required)
    //   - productName: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sannythda23@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'quantity', 'sku', 'createdAt', 'updatedAt', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.quantity is number && data.quantity >= 0 &&
             data.sku is string && data.sku.size() > 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.createdBy is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'action', 'productId', 'productName', 'timestamp']) &&
             data.userId is string &&
             data.userName is string &&
             data.action is string &&
             data.productId is string &&
             data.productName is string &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && (isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt'])));
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update, delete: if false;
    }
  }
}
